                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=17.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">SELECT
    id,
    numero_trabalhador,
    CASE
    WHEN genero = 'M' THEN 'Masculino'
    WHEN genero IS NULL THEN NULL
    ELSE 'Feminino'
END AS Genero,
    nome_completo,
    LEFT(nome_completo, CHARINDEX(' ', nome_completo + ' ') - 1) AS PrimeiroNome,
    RIGHT(nome_completo, CHARINDEX(' ', REVERSE(nome_completo) + ' ') - 1) AS UltimoNome,
    COALESCE(cartao_cidadao, autorizacao_de_residencia) AS DocumentoIdentificacao,
    nif,
    niss,
    morada,
    codigo_postal,
    id_freguesia,
    id_pais_nacionalidade,
    id_pais_naturalidade,
    telefone,
    email_pessoal,
    email_profissional
FROM dsa.Trabalhador;</property>

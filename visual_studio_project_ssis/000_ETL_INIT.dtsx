[Beginning of Year Key], &#xA;    [Fiscal Year Month Key], &#xA;    [Fiscal Year Quarter Key], &#xA;    [Fiscal Year Half of Year Key], &#xA;    [ISO Week Number], &#xA;    [Portuguese Holiday Flag], &#xA;    [Portuguese Holiday Name], &#xA;    [Portuguese Holiday Type]&#xA;)&#xA;VALUES (&#xA;    '1900-01-01', -- [Date]&#xA;    19000101,           -- [DateKey]&#xA;    -1,           -- [Day Number]&#xA;    'n/a',        -- [Day]&#xA;    'n/a',        -- [Day of Year]&#xA;    -1,           -- [Day of Year Number]&#xA;    'n/a',        -- [Day of Week English]&#xA;    'n/a',        -- [Day of Week Portuguese]&#xA;    -1,           -- [Day of Week Number]&#xA;    'n/a',        -- [Week of Year]&#xA;    'n/a',        -- [Month English]&#xA;    'n/a',        -- [Month Portuguese]&#xA;    'n/a',        -- [Short Month]&#xA;    'na',        -- [Quarter]&#xA;    'n/a',        -- [Half of Year]&#xA;    '1900-01-01', -- [Beginning of Month]&#xA;    '1900-01-01', -- [Beginning of Quarter]&#xA;    '1900-01-01', -- [Beginning of Half Year]&#xA;    '1900-01-01', -- [Beginning of Year]&#xA;    'n/a',        -- [Beginning of Month Label]&#xA;    'n/a',        -- [Beginning of Month Label Short]&#xA;    'n/a',        -- [Beginning of Quarter Label]&#xA;    'n/a',        -- [Beginning of Quarter Label Short]&#xA;    'n/a',        -- [Beginning of Half Year Label]&#xA;    'n/a',        -- [Beginning of Half Year Label Short]&#xA;    'n/a',        -- [Beginning of Year Label]&#xA;    'n/a',        -- [Beginning of Year Label Short]&#xA;    'n/a',        -- [Calendar Day Label]&#xA;    'n/a',        -- [Calendar Day Label Short]&#xA;    -1,           -- [Calendar Week Number]&#xA;    'n/a',        -- [Calendar Week Label]&#xA;    -1,           -- [Calendar Month Number]&#xA;    'n/a',        -- [Calendar Month Label]&#xA;    'n/a',        -- [Calendar Month Year Label]&#xA;    -1,           -- [Calendar Quarter Number]&#xA;    'n/a',        -- [Calendar Quarter Label]&#xA;    'n/a',     
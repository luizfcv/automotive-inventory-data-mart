                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=17.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">SELECT 
    id_produto,
    id_trabalhador,
    id_armazem,
    id_fornecedor,
    'Não Aplicável' AS tipo_saida,
    quantidade AS quantidade_movimentada,
    data_hora,
    identificador_documento,
    'Entrada' AS movimento
FROM dsa.entrada

UNION ALL

SELECT 
    id_produto,
    id_trabalhador,
    id_armazem,
    NULL AS id_fornecedor,         
    tipo_saida,
    quantidade * -1 AS quantidade_movimentada,
    data_hora,
    identificador_documento,
    'Saída' AS movimento
FROM dsa.saida;</property>
